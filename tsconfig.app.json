{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "vitest.config.ts"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",           // ← Add this
      "DOM.Iterable"   // ← And this (recommended)
    ],
    "module": "ESNext",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}